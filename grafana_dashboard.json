{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Graphics --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Current Active Players",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "poker_active_players_total", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "title": "Current Active Rooms",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "poker_active_rooms", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "title": "Live WS Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "poker_ws_connections_active", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto" }
    },
    {
      "title": "Total Rooms (Lifetime)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "poker_rooms_created_total", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto" }
    },
    {
      "title": "Player Actions (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(poker_player_actions_total[1m])) by (action)",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "WebSocket Traffic by Action",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(increase(poker_ws_messages_received_total[1h])) by (action)",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Players Per Room",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(poker_players_per_room_sum) / sum(poker_players_per_room_count)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 20, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      }
    },
    {
      "title": "Room Size Distribution (Histogram)",
      "type": "barGauge",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "sum(increase(poker_players_per_room_bucket[1h])) by (le)",
          "legendFormat": "{{le}} players",
          "refId": "A"
        }
      ],
      "options": { "displayMode": "gradient", "orientation": "horizontal" }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["planning-poker", "go"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Planning Poker Service Dashboard"
}
